TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_with_your_api_hash

# Optional: use an existing proxy directly.
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:10808
# TELEGRAM_PROXY_URL=http://192.168.1.10:7890

# Optional: used by `telegram-nas xray-config`.
# VLESS_LINK=vless://uuid@example.com:443?encryption=none&security=tls&type=ws&path=%2F#name
